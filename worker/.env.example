# Copy this file to either `.env.development` or `.env.production`.
# Worker does not connect to MySQL directly.

# Backend internal API
BACKEND_INTERNAL_URL=http://127.0.0.1:9001
BACKEND_INTERNAL_API_KEY=1234567890

# Redis / BullMQ
REDIS_HOST=your-redis-host
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_DB=0

# Shared Qdrant
QDRANT_URL=http://shared-qdrant-host:6333
QDRANT_COLLECTION_NAME=user_impressions_dev
QDRANT_PROFILE_COLLECTION_NAME=user_profile_memories_dev

# DashScope
DASHSCOPE_API_KEY=replace-with-your-dashscope-api-key
DASHSCOPE_EMBEDDING_URL=https://dashscope.aliyuncs.com/api/v1/services/embeddings/text-embedding/text-embedding
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIM=1024
DASHSCOPE_QWEN_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
DASHSCOPE_QWEN_MODEL=qwen3.6-plus

# Worker
WORKER_CONCURRENCY=5
FACT_WORKER_CONCURRENCY=5
